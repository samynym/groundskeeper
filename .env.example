# Local checkout of the target site repo (Steady web)
TARGET_REPO_PATH=/path/to/target-site-checkout
# Target site public origin
TARGET_ORIGIN=https://growsteady.me
# GSC (reused from Steady's seo-loop.mjs)
GSC_SA_JSON=/absolute/path/to/service-account.json
GSC_PROPERTY=sc-domain:growsteady.me
# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Fallback for cloud environments (e.g. claude.ai routines) that reserve and
# strip ANTHROPIC_API_KEY — set the GEO engine's key under this name there.
GEO_ENGINE_API_KEY=sk-ant-...
GROUNDSKEEPER_MODEL=claude-sonnet-4-6
# Git base branch on the target repo
TARGET_BASE_BRANCH=main
# Presence probe (SP2)
PRESENCE_DIR=presence
PRESENCE_RUNS=2
# IndexNow (inert until https://<brandDomain>/<key>.txt is deployed via a Steady PR)
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=
